# ============================================================
# 会计平台 — 生产环境变量模板
# 复制为 .env 并填写真实值
# ============================================================

# PostgreSQL
POSTGRES_USER=accounting
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=accounting
DATABASE_URL=postgresql+asyncpg://accounting:CHANGE_ME_DB_PASSWORD@postgres:5432/accounting

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://sfxfs.org","http://localhost:3000"]
FRONTEND_URL=http://sfxfs.org

# Service URLs (internal, Docker 服务名)
AUTH_SERVICE_URL=http://auth-service:8000
TENANT_SERVICE_URL=http://tenant-service:8000

# Tenant RBAC — 服务间共享 token
TENANT_INTERNAL_API_TOKEN=CHANGE_ME

# Auth — Email verification (QQ Mail SMTP)
# 设为 false 可在无 SMTP 时跳过邮件验证
EMAIL_VERIFICATION_REQUIRED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM_EMAIL=your-email@qq.com
SMTP_FROM_NAME=Accounting Platform
SMTP_USE_TLS=true
