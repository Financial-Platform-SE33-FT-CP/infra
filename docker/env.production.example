# ============================================================
# 会计平台 — 生产环境变量 (单机 Compose)
# ============================================================
# 用法:
#   1. 修改下方密码和密钥
#   2. docker compose --env-file .env.production -f docker-compose.prod.yml up -d
# ============================================================

# PostgreSQL
POSTGRES_USER=accounting
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=accounting
DATABASE_URL=postgresql+asyncpg://accounting:CHANGE_ME_DB_PASSWORD@postgres:5432/accounting

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS='["http://localhost:3000"]'

# Service URLs (internal, 使用 Docker 服务名)
AUTH_SERVICE_URL=http://auth-service:8000
