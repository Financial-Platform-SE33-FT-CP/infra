# ============================================================
# 会计平台 — Docker Swarm 环境变量模板
# ============================================================
# 用法:
#   1. cp env.swarm.template env.swarm
#   2. 填写真实值
#   3. source env.swarm
#   4. ./scripts/deploy-swarm.sh
#
# ⚠️ 此文件包含敏感信息，请勿提交到版本库！
#    已添加到 .gitignore。
# ============================================================

# --------------------------------------------------
# 数据库连接 (需与 docker secret database_url 保持一致)
# --------------------------------------------------
export DATABASE_URL="postgresql+asyncpg://accounting:YOUR_DB_PASSWORD@postgres:5432/accounting"

# --------------------------------------------------
# JWT 密钥 (需与 docker secret jwt_secret 保持一致)
# --------------------------------------------------
export JWT_SECRET="your-jwt-secret-at-least-32-characters-long"

# --------------------------------------------------
# NFS 服务器地址（如需自动配置 volume，可留空）
# --------------------------------------------------
# export NFS_SERVER="nfs-server.example.com"
